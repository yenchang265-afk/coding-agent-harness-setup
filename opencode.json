{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "bundles/*/AGENTS.md"
  ],
  "lsp": {
    "typescript": {
      "command": [
        "typescript-language-server",
        "--stdio"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".mjs",
        ".cjs"
      ]
    },
    "java": {
      "command": [
        "jdtls"
      ],
      "extensions": [
        ".java"
      ]
    }
  },
  "experimental": {
    "hook": {
      "file_edited": {
        "*": [
          {
            "command": [
              "bundles/core/hooks/format.sh"
            ]
          }
        ]
      }
    }
  },
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    },
    "azure-devops": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@azure-devops/mcp",
        "YOUR_ADO_ORG"
      ],
      "environment": {},
      "enabled": false
    }
  }
}
